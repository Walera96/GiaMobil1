DO $$
BEGIN
    IF NOT EXISTS (
        SELECT 1 FROM pg_constraint WHERE conname = 'student_unique_name_group'
    ) THEN
        ALTER TABLE student ADD CONSTRAINT student_unique_name_group
            UNIQUE (last_name, first_name, middle_name, group_id);
    END IF;
END $$
